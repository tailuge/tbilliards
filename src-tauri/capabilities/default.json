{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions for the remote billiards game",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": ["https://billiards.tailuge.workers.dev"]
  },
  "permissions": [
    "core:default",
    "window-state:default"
  ]
}
