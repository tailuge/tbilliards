{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Billiards",
  "version": "0.1.0",
  "identifier": "com.tailuge.billiards",
  "build": {
    "frontendDist": "https://billiards.tailuge.workers.dev/lobby",
    "devUrl": "https://billiards.tailuge.workers.dev/lobby"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "Billiards",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "userAgent": "Tauri"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "templates/billiards.desktop",
        "files": {
          "icons/32x32.png": "/usr/share/icons/hicolor/32x32/apps/com.tailuge.billiards.png",
          "icons/128x128.png": "/usr/share/icons/hicolor/128x128/apps/com.tailuge.billiards.png",
          "icons/128x128@2x.png": "/usr/share/icons/hicolor/256x256/apps/com.tailuge.billiards.png",
          "icons/icon.png": "/usr/share/icons/hicolor/512x512/apps/com.tailuge.billiards.png"
        }
      },
      "rpm": {
        "desktopTemplate": "templates/billiards.desktop",
        "files": {
          "icons/32x32.png": "/usr/share/icons/hicolor/32x32/apps/com.tailuge.billiards.png",
          "icons/128x128.png": "/usr/share/icons/hicolor/128x128/apps/com.tailuge.billiards.png",
          "icons/128x128@2x.png": "/usr/share/icons/hicolor/256x256/apps/com.tailuge.billiards.png",
          "icons/icon.png": "/usr/share/icons/hicolor/512x512/apps/com.tailuge.billiards.png"
        }
      }
    }
  }
}
